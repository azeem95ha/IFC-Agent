# ── Required ─────────────────────────────────────────────────────────────────
# Google Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# ── LLM settings ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2

# ── Session storage ───────────────────────────────────────────────────────────
# Directory where session IFC files are stored (defaults to system temp dir)
IFC_SESSION_DIR=
# How long a session lives without activity, in seconds (default: 2 hours)
SESSION_TTL_SECONDS=7200
# How often the cleanup loop runs, in seconds (default: 10 minutes)
CLEANUP_INTERVAL_SECONDS=600

# ── File uploads ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
